{
  "info": {
    "name": "BidKita - Demo Presentasi OOP",
    "description": "Skenario presentasi OOP: Start, Process, Exception, End.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. START (Persiapan)",
      "item": [
        {
          "name": "Login Admin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api", "auth", "login"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@bidkita.com\",\n  \"password\": \"admin123\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": ["pm.collectionVariables.set('admin_token', pm.response.json().accessToken);"] } }]
        },
        {
          "name": "Login Seller",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api", "auth", "login"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"seller1@bidkita.com\",\n  \"password\": \"seller123\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": ["pm.collectionVariables.set('seller_token', pm.response.json().accessToken);"] } }]
        },
        {
          "name": "Login Buyer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api", "auth", "login"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"buyer1@bidkita.com\",\n  \"password\": \"buyer123\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": ["pm.collectionVariables.set('buyer_token', pm.response.json().accessToken);"] } }]
        }
      ]
    },
    {
      "name": "2. PROCESS (Inisiasi Bisnis)",
      "item": [
        {
          "name": "Seller Buat Lelang",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auctions", "host": ["{{base_url}}"], "path": ["api", "auctions"] },
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{seller_token}}", "type": "string" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"category\": \"ELEKTRONIK\",\n  \"title\": \"MacBook Pro M2\",\n  \"description\": \"Kondisi mulus, ex-developer IF-48-12.\",\n  \"condition\": \"BEKAS_BAIK\",\n  \"startingPrice\": 15000000,\n  \"duration\": 5,\n  \"buyNowPrice\": 20000000,\n  \"brand\": \"Apple\",\n  \"type\": \"Laptop\",\n  \"warrantyStatus\": true\n}"
            }
          },
          "event": [{ "listen": "test", "script": { "exec": ["pm.collectionVariables.set('demo_auction_id', pm.response.json().auctionId);"] } }]
        }
      ]
    },
    {
      "name": "3. EXCEPTION (Uji Validasi OOP)",
      "item": [
        {
          "name": "GAGAL 1: Bid Lelang PENDING",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auctions/{{demo_auction_id}}/bid", "host": ["{{base_url}}"], "path": ["api", "auctions", "{{demo_auction_id}}", "bid"] },
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{buyer_token}}", "type": "string" }] },
            "body": { "mode": "raw", "raw": "{\n  \"amount\": 16000000\n}" }
          }
        },
        {
          "name": "Admin Approve Lelang (Buka Akses)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auctions/{{demo_auction_id}}/approve", "host": ["{{base_url}}"], "path": ["api", "auctions", "{{demo_auction_id}}", "approve"] },
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{admin_token}}", "type": "string" }] }
          }
        },
        {
          "name": "GAGAL 2: Saldo Wallet Kurang",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auctions/{{demo_auction_id}}/bid", "host": ["{{base_url}}"], "path": ["api", "auctions", "{{demo_auction_id}}", "bid"] },
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{buyer_token}}", "type": "string" }] },
            "body": { "mode": "raw", "raw": "{\n  \"amount\": 16000000\n}" }
          }
        },
        {
          "name": "Buyer Top Up Wallet",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/wallet/topup", "host": ["{{base_url}}"], "path": ["api", "wallet", "topup"] },
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{buyer_token}}", "type": "string" }] },
            "body": { "mode": "raw", "raw": "{\n  \"amount\": 25000000,\n  \"paymentMethod\": \"BANK_TRANSFER\"\n}" }
          }
        },
        {
          "name": "GAGAL 3: Bid Terlalu Rendah",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auctions/{{demo_auction_id}}/bid", "host": ["{{base_url}}"], "path": ["api", "auctions", "{{demo_auction_id}}", "bid"] },
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{buyer_token}}", "type": "string" }] },
            "body": { "mode": "raw", "raw": "{\n  \"amount\": 10000000\n}" }
          }
        }
      ]
    },
    {
      "name": "4. END (Resolusi & Verifikasi Data)",
      "item": [
        {
          "name": "SUKSES: Buyer Pasang Bid Valid",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auctions/{{demo_auction_id}}/bid", "host": ["{{base_url}}"], "path": ["api", "auctions", "{{demo_auction_id}}", "bid"] },
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{buyer_token}}", "type": "string" }] },
            "body": { "mode": "raw", "raw": "{\n  \"amount\": 16000000\n}" }
          }
        },
        {
          "name": "SUKSES: Buyer Buy Now (Lelang Selesai)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auctions/{{demo_auction_id}}/buynow", "host": ["{{base_url}}"], "path": ["api", "auctions", "{{demo_auction_id}}", "buynow"] },
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{buyer_token}}", "type": "string" }] }
          }
        },
        {
          "name": "Verifikasi 1: Saldo Wallet Terpotong",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/api/wallet", "host": ["{{base_url}}"], "path": ["api", "wallet"] },
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{buyer_token}}", "type": "string" }] }
          }
        },
        {
          "name": "Verifikasi 2: Notifikasi Barang Terjual (Seller)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/api/notifications", "host": ["{{base_url}}"], "path": ["api", "notifications"] },
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{seller_token}}", "type": "string" }] }
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080", "type": "string" },
    { "key": "admin_token", "value": "", "type": "string" },
    { "key": "seller_token", "value": "", "type": "string" },
    { "key": "buyer_token", "value": "", "type": "string" },
    { "key": "demo_auction_id", "value": "", "type": "string" }
  ]
}